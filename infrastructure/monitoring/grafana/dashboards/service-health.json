{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Service Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "targets": [
        { "expr": "up", "legendFormat": "{{ job }}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "expr": "rate(http_requests_total[5m])", "legendFormat": "{{ job }}", "refId": "A" }
      ],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "title": "Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "expr": "rate(http_requests_total{status=~\"5..\"}[5m])", "legendFormat": "{{ job }}", "refId": "A" }
      ],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "title": "Latency p95 (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "{{ job }}", "refId": "A" }
      ],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "title": "Memory Usage (MB)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        { "expr": "process_resident_memory_bytes / 1024 / 1024", "legendFormat": "{{ job }}", "refId": "A" }
      ],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["plos", "health"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "PLOS Service Health Overview",
  "uid": "plos-service-health"
}
