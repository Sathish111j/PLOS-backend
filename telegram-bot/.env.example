# ── Telegram ──────────────────────────────────────────────────────────────────
# Get from @BotFather
TELEGRAM_BOT_TOKEN=

# Leave empty for long-polling (local dev). Set to your HTTPS domain for prod.
# The bot will register https://your.domain.com/bot as the webhook.
WEBHOOK_URL=
WEBHOOK_SECRET=your_random_secret_here
WEBHOOK_PORT=8443

# ── Backend API ───────────────────────────────────────────────────────────────
# Service name inside Docker Compose, or full URL for external deployment
API_BASE_URL=http://api-gateway:8000/api/v1

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:plos_redis_secure_2025@redis:6379/0

# ── Session TTL ───────────────────────────────────────────────────────────────
# Must match your backend JWT expiry.
JWT_TTL=3600
